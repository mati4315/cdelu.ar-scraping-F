# MySQL Database
DB_HOST=your_db_host
DB_PORT=3306
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=your_db_name

# Facebook Session (coloca las cookies exportadas del navegador en cookies.json)
# FB_COOKIES_FILE=./cookies.json

# Feed URLs (opcional, por defecto usa grupos + cronologico)
# FEED_URLS=https://www.facebook.com/groups/feed/,https://www.facebook.com/?filter=all&sk=h_chr

# Telegram Alerts (opcional, dejar vacio para desactivar)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Execution Control
DRY_RUN=false
MAX_POSTS_PER_RUN=40
MIN_DELAY_MS=4000
MAX_DELAY_MS=12000
REQUEST_TIMEOUT_MS=15000
MAX_RETRIES=3
COOLDOWN_BASE_MINUTES=30
MAX_COOLDOWN_HOURS=6
DOWNLOAD_IMAGES=true
IMAGE_DIR=./images
IMAGE_PUBLIC_BASE_URL=https://bot.cdelu.io/images
GENERATE_THUMBNAILS=true
THUMBNAIL_WIDTH=500
THUMBNAIL_HEIGHT=281
THUMBNAIL_QUALITY=58
THUMBNAIL_MAX_SIZE_KB=90
COMPRESS_IMAGES=true
MAX_IMAGE_SIZE_KB=190
IMAGE_COMPRESSION_QUALITY=82

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Database checker (opcional)
# CHECK_DB_LIMIT=10
