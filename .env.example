# ==============================================================
# Facebook Scraper - Variables de Entorno
# Renombrar este archivo a .env y completar los valores
# ==============================================================

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=facebook_scraper

# --- Facebook Session ---
# Copiar las cookies desde el navegador (formato JSON array de objetos cookie)
# Ver: cookies.json en el mismo directorio
FB_COOKIES_FILE=./cookies.json

# --- Telegram Alerts (opcional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Execution Control ---
DRY_RUN=false
MAX_POSTS_PER_RUN=40
MIN_DELAY_MS=4000
MAX_DELAY_MS=12000
REQUEST_TIMEOUT_MS=15000
MAX_RETRIES=3
COOLDOWN_BASE_MINUTES=30
MAX_COOLDOWN_HOURS=6

# --- Logging ---
LOG_LEVEL=info
LOG_DIR=./logs
